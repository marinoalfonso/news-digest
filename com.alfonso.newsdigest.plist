<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

  <!-- Identificatore univoco del job -->
  <key>Label</key>
  <string>com.alfonso.newsdigest</string>

  <key>ProgramArguments</key>
<array>
  <string>/bin/bash</string>
  <string>/Users/alfonsomarino/projects/news-digest/smart-run.sh</string>
</array>

  <!-- Orario: ogni giorno alle 09:00 -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <!-- Variabili d'ambiente (opzionale se usi già .env con dotenv) -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin</string>
  </dict>

  <!-- Directory di lavoro: deve essere la cartella del progetto -->
  <key>WorkingDirectory</key>
  <string>/Users/alfonsomarino/projects/news-digest</string>

  <!-- Log stdout e stderr per debug -->
  <key>StandardOutPath</key>
  <string>/Users/alfonsomarino/projects/news-digest/logs/digest.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/alfonsomarino/projects/news-digest/logs/digest_error.log</string>

  <!-- Riprova se il Mac era spento alle 9 -->
  <key>RunAtLoad</key>
  <true/>

</dict>
</plist>